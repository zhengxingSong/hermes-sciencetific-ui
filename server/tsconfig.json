{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "../dist/server",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true
  },
  "include": ["src/**/*.ts"],
  "ts-node": {
    "compilerOptions": {
      "target": "ES2022",
      "module": "commonjs"
    }
  }
}
